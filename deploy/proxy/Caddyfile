# Single-origin reverse proxy. Serves the UI at / and the API at /api on one
# host, so the whole app sits behind one automatically-provisioned certificate.
#
#   /api/*  ->  backend  (the /api prefix is stripped before forwarding)
#   /*      ->  frontend
#
# Naming a real domain here switches Caddy into automatic HTTPS: on first run it
# obtains and renews a Let's Encrypt certificate (needs ports 80 + 443 open and
# the domain pointed at this host) and redirects http -> https for free.

(app) {
	# handle_path strips the matched prefix, so /api/chat -> /chat upstream.
	handle_path /api/* {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}

ragassistant.duckdns.org {
	import app
}
