# ---------------------------------------------------------------------------
# Copy this file to .env and adjust values. Never commit your real .env.
# ---------------------------------------------------------------------------

# --- Database (pgvector) ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full SQLAlchemy/psycopg URL (built from the above in docker-compose)
DATABASE_URL=postgresql://rag:ragpassword@db:5432/ragdb

# --- LLM provider selection ---
# One of: ollama | gemini | openai
LLM_PROVIDER=ollama

# Ollama (free, local). Chat model must be pulled: `ollama pull llama3.1`
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# Google Gemini (free tier). Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (paid)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings (local, free, CPU via fastembed) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- Retrieval tuning ---
RETRIEVE_TOP_K=20
FINAL_TOP_K=5
USE_RERANKER=true
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# --- App ---
BACKEND_CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=25

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
